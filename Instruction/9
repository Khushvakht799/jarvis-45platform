"language": "python",
"content": "from core.metacontrol.memory import find_similar_commands, get_best_sequence\n\ndef adapt_avgr(command, avgr, syvgr):\n    if syvgr[\"symptom\"].get(\"deviation\", 0) != 0:\n        print(\"[Evolve] Deviation detected, adapting AVGr...\")\n        similar = find_similar_commands(command)\n        if similar:\n            successful = [s for s in similar if s[\"syvgr\"][\"symptom\"][\"status\"] == \"success\"]\n            if successful:\n                last_success = successful[-1]\n                if \"repeat\" in last_success[\"avgr\"][\"intent\"]:\n                    avgr[\"intent\"][\"repeat\"] = last_success[\"avgr\"][\"intent\"][\"repeat\"]\n                    print(f\"[Evolve] Adjusted repeat to {avgr['intent']['repeat']}\")\n    return avgr\n\ndef evolve_sqvgr(command, sqvgr, syvgr):\n    # Если есть сохранённая лучшая последовательность для этой команды, используем её\n    best = get_best_sequence(command)\n    if best:\n        print(\"[Evolve] Found better sequence in memory, applying\")\n        return best\n    \n    # Здесь можно добавить логику оптимизации последовательности\n    # Например, если deviation=0 и статус success, сохраняем как эталон (уже в memory.py)\n    return sqvgr"
