"content": "def optimize_sequence(sequence, intent):\n """\n Пытается найти более эффективную последовательность действий.\n Правила оптимизации:\n 1. Если несколько одинаковых console_output подряд -> заменить на цикл\n 2. Если есть лишние init_counter (повторная инициализация) -> убрать дубли\n 3. Если можно объединить increment в один шаг с большим шагом\n """\n print("[Optimizer] Analyzing sequence for optimization...")\n \n # Копируем исходную последовательность\n new_seq = sequence.copy()\n \n # Оптимизация 1: Поиск повторяющихся console_output\n i = 0\n while i < len(new_seq) - 1:\n if new_seq[i]["action"] == "console_output" and new_seq[i+1]["action"] == "console_output":\n # Нашли два подряд одинаковых вывода\n if new_seq[i]["value"] == new_seq[i+1]["value"]:\n print(f"[Optimizer] Found repeated outputs at steps {i+1}, {i+2}")\n # Считаем, сколько их всего подряд\n j = i\n count = 0\n while j < len(new_seq) and new_seq[j]["action"] == "console_output" and new_seq[j]["value"] == new_seq[i]["value"]:\n count += 1\n j += 1\n \n # Заменяем блок на цикл\n if count > 2:\n print(f"[Optimizer] Replacing {count} repeats with loop")\n # Удаляем все эти шаги\n del new_seq[i:j]\n # Вставляем цикл\n loop_start = {\n "step": i+1,\n "action": "loop_start",\n "condition": f"count < {count}"\n }\n loop_body = {\n "step": i+2,\n "action": "console_output",\n "value": new_seq[i]["value"]\n }\n loop_increment = {\n "step": i+3,\n "action": "increment",\n "target": "count",\n "by": 1\n }\n loop_end = {\n "step": i+4,\n "action": "loop_end"\n }\n # Вставляем новые шаги\n new_seq[i:i] = [loop_start, loop_body, loop_increment, loop_end]\n # Перенумеруем\n for idx, step in enumerate(new_seq):\n step["step"] = idx + 1\n break\n i += 1\n \n # Оптимизация 2: Удаление лишних init_counter\n init_targets = set()\n i = 0\n while i < len(new_seq):\n if new_seq[i]["action"] == "init_counter":\n target = new_seq[i]["target"]\n if target in init_targets:\n print(f"[Optimizer] Removing duplicate init_counter for {target}")\n del new_seq[i]\n continue\n else:\n init_targets.add(target)\n i += 1\n \n # Перенумеруем финальную последовательность\n for idx, step in enumerate(new_seq):\n step["step"] = idx + 1\n \n if new_seq != sequence:\n print(f"[Optimizer] Sequence optimized: {len(sequence)} -> {len(new_seq)} steps")\n else:\n print("[Optimizer] No optimizations applied")\n \n return {"sequence": new_seq}"
},
