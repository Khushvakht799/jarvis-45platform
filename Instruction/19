"language": "html",
"content": "<!DOCTYPE html>\n<html>\n<head>\n    <title>Jarvis 3.0 Dashboard</title>\n    <link rel=\"stylesheet\" href=\"/static/style.css\">\n    <script src=\"/static/script.js\" defer></script>\n</head>\n<body>\n    <div class=\"container\">\n        <header>\n            <h1>Jarvis 3.0 Control Panel</h1>\n            <div class=\"status-bar\">\n                <span id=\"node-count\">Nodes: 0</span>\n                <span id=\"cache-status\">Cache: --</span>\n                <span id=\"distributed-status\">Distributed: --</span>\n            </div>\n        </header>\n        \n        <nav>\n            <a href=\"/\" class=\"active\">Dashboard</a>\n            <a href=\"/memory\">Memory</a>\n            <a href=\"/nodes\">Nodes</a>\n            <a href=\"/tasks\">Tasks</a>\n            <a href=\"/compiler\">Compiler</a>\n        </nav>\n        \n        <main>\n            <section class=\"command-panel\">\n                <h2>Execute Command</h2>\n                <form id=\"command-form\">\n                    <input type=\"text\" id=\"command-input\" placeholder=\"Enter command...\">\n                    <select id=\"mode-select\">\n                        <option value=\"local\">Local</option>\n                        <option value=\"distributed\">Distributed</option>\n                    </select>\n                    <button type=\"submit\">Execute</button>\n                </form>\n                <div id=\"command-output\"></div>\n            </section>\n            \n            <div class=\"stats-grid\">\n                <section class=\"stats-card\">\n                    <h3>System Health</h3>\n                    <div id=\"system-stats\">Loading...</div>\n                </section>\n                \n                <section class=\"stats-card\">\n                    <h3>Recent Tasks</h3>\n                    <div id=\"recent-tasks\">Loading...</div>\n                </section>\n                \n                <section class=\"stats-card\">\n                    <h3>Active Nodes</h3>\n                    <div id=\"active-nodes\">Loading...</div>\n                </section>\n            </div>\n            \n            <section class=\"log-panel\">\n                <h2>System Log</h2>\n                <div id=\"system-log\"></div>\n            </section>\n        </main>\n    </div>\n</body>\n</html>"
