"content": "<!DOCTYPE html>\n<html>\n<head>\n    <title>Jarvis - Task Scheduler</title>\n    <link rel=\"stylesheet\" href=\"/static/style.css\">\n    <script src=\"/static/script.js\" defer></script>\n</head>\n<body>\n    <div class=\"container\">\n        <header>\n            <h1>Jarvis Task Scheduler</h1>\n            <div class=\"status-bar\">\n                <span id=\"node-count\">Nodes: 0</span>\n                <span id=\"cache-status\">Cache: --</span>\n            </div>\n        </header>\n        \n        <nav>\n            <a href=\"/\">Dashboard</a>\n            <a href=\"/memory\">Memory</a>\n            <a href=\"/nodes\">Nodes</a>\n            <a href=\"/tasks\" class=\"active\">Tasks</a>\n            <a href=\"/compiler\">Compiler</a>\n        </nav>\n        \n        <main>\n            <section class=\"task-controls\">\n                <h2>Schedule New Task</h2>\n                <form id=\"task-form\">\n                    <input type=\"text\" id=\"task-command\" placeholder=\"Command\">\n                    <select id=\"task-type\">\n                        <option value=\"once\">One-time</option>\n                        <option value=\"recurring\">Recurring</option>\n                    </select>\n                    <input type=\"number\" id=\"task-interval\" placeholder=\"Interval (seconds)\" value=\"60\">\n                    <button type=\"submit\">Schedule</button>\n                </form>\n            </section>\n            \n            <section class=\"task-list\">\n                <h2>Scheduled Tasks</h2>\n                <div id=\"tasks-table\">\n                    <table>\n                        <thead>\n                            <tr>\n                                <th>Task ID</th>\n                                <th>Command</th>\n                                <th>Next Run</th>\n                                <th>Type</th>\n                                <th>Actions</th>\n                            </tr>\n          